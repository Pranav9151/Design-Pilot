# ═══════════════════════════════════════════════════════════════════
# DesignPilot MECH — Environment Configuration
# Copy to .env and fill in real values. Never commit .env to git.
# ═══════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────
APP_ENV=development              # development | staging | production
APP_NAME="DesignPilot MECH"
APP_VERSION=1.0.0-alpha.1
LOG_LEVEL=INFO
DEBUG=true

# ── Server ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ───────────────────────────────────────────────────────
# Local Postgres for dev; Supabase connection string for staging/prod.
# Format: postgresql+asyncpg://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://designpilot:designpilot@localhost:5433/designpilot_dev
DATABASE_URL_SYNC=postgresql://designpilot:designpilot@localhost:5433/designpilot_dev
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_ECHO=false

# ── Supabase (used from Week 1 for Auth + RLS) ─────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings
SUPABASE_JWT_ALGORITHM=HS256
SUPABASE_JWT_AUDIENCE=authenticated

# ── Redis (cache + rate limits) ────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ── LLM (wired Week 3) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# ── Object storage (wired Week 3) ──────────────────────────────────
# Cloudflare R2 endpoint + credentials
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=designpilot-designs
R2_ENDPOINT_URL=https://YOUR_ACCOUNT.r2.cloudflarestorage.com

# ── Observability ──────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ── Feature flags (v1.0 only exposes solo features) ────────────────
FEATURE_TEAMS=false              # v1.5 enables teams
FEATURE_MOBILE=false             # v1.5
FEATURE_FEA=false                # v1.5 Triple-Lock R3
FEATURE_2D_DRAWINGS=false        # v1.5

# ── Rate limits (per user, monthly) ────────────────────────────────
RATE_LIMIT_FREE_DESIGNS_PER_MONTH=5
RATE_LIMIT_PRO_DESIGNS_PER_MONTH=500
RATE_LIMIT_IP_PER_MINUTE=100
RATE_LIMIT_IP_PER_HOUR=1000

# ── Security ───────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Sandbox (Week 2) ───────────────────────────────────────────────
SANDBOX_IMAGE=designpilot/cadquery-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT_MB=512
SANDBOX_CPU_QUOTA=200000
# Set to true to skip real Docker execution during local development.
# Lets you test LLM→pipeline→DB without building the sandbox Docker image.
# MUST be false (or absent) in production.
SANDBOX_SKIP_FOR_DEV=false


SANDBOX_SKIP_FOR_DEV=true
ANTHROPIC_API_KEY=sk-ant-...
