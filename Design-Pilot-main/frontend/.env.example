# ════════════════════════════════════════════════════════════════════
# DesignPilot MECH — Frontend Environment
# Copy to frontend/.env and fill in real values.
# Never commit .env to git.
# ════════════════════════════════════════════════════════════════════

# Supabase project credentials (from Supabase dashboard → Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Backend API base (Vite dev proxy rewrites /api → this)
# In production this is same-origin; no variable needed.
# VITE_API_BASE_URL=http://localhost:8000
